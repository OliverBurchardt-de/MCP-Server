{
  "name": "datev-mcp-server",
  "version": "0.2.0",
  "description": "MCP-Server für DATEV: beantwortet Fragen zu Salden, offenen Posten und Buchungen — aus EXTF-Exportdateien oder live aus der DATEV-Cloud (Accounting Data Exchange)",
  "scripts": {
    "test": "vitest run",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src test eslint.config.js --ext .ts",
    "format": "prettier --write .",
    "prepare": "npm run build",
    "dev": "tsx src/index.ts"
  },
  "keywords": [
    "datev",
    "mcp",
    "model-context-protocol",
    "typescript"
  ],
  "author": "Burchardt & Kollegen (Basis: FinRobotics datev-mcp-server, MIT)",
  "license": "MIT",
  "type": "module",
  "private": false,
  "bin": {
    "datev-mcp-server": "./dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "csv-parse": "^6.2.1",
    "iconv-lite": "^0.7.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
